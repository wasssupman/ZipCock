generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Region {
  id         Int        @id @default(autoincrement())
  name       String
  cortarNo   String     @unique
  cortarType String // sido, sigungu, dong
  parentId   Int?
  parent     Region?    @relation("RegionHierarchy", fields: [parentId], references: [id])
  children   Region[]   @relation("RegionHierarchy")
  isActive   Boolean    @default(false)
  listings   Listing[]
  crawlLogs  CrawlLog[]
  createdAt  DateTime   @default(now())
}

model Listing {
  id             Int            @id @default(autoincrement())
  naverArticleId String         @unique
  regionId       Int
  region         Region         @relation(fields: [regionId], references: [id])
  propertyType   String
  tradeType      String
  price          Int
  rentPrice      Int?
  area           Float?
  floor          String?
  buildingName   String?
  address        String?
  description    String?
  naverUrl            String?
  articleConfirmDate  String?
  firstSeenAt         DateTime       @default(now())
  lastSeenAt     DateTime       @default(now())
  isActive       Boolean        @default(true)
  priceLevel     String?
  infraLevel     String?
  aiAnalysis     String?
  analyzedAt     DateTime?
  priceHistory   PriceHistory[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([regionId, isActive, lastSeenAt])
  @@index([isActive, firstSeenAt])
  @@index([isActive, updatedAt])
  @@index([regionId, propertyType, tradeType, isActive])
}

model AlertConfig {
  id                  Int      @id @default(autoincrement())
  channel             String
  webhookUrl          String?
  botToken            String?
  chatId              String?
  filterPropertyTypes String?
  filterTradeTypes    String?
  filterMinPrice      Int?
  filterMaxPrice      Int?
  filterRegionIds     String?
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
}

model CrawlLog {
  id                  Int       @id @default(autoincrement())
  regionId            Int
  region              Region    @relation(fields: [regionId], references: [id])
  startedAt           DateTime  @default(now())
  finishedAt          DateTime?
  totalFound          Int       @default(0)
  newListings         Int       @default(0)
  updatedListings     Int       @default(0)
  deactivatedListings Int       @default(0)
  status              String    @default("running")
  errorMessage        String?
}

model PriceHistory {
  id        Int      @id @default(autoincrement())
  listingId Int
  listing   Listing  @relation(fields: [listingId], references: [id])
  oldPrice  Int
  newPrice  Int
  changedAt DateTime @default(now())

  @@index([listingId])
}
